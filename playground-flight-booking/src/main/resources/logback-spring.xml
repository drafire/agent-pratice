<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        企业级日志配置
         - dev 环境：彩色控制台，可读性强
         - prod 环境：JSON 格式，方便 ELK 采集
    -->

    <!-- ==================== 环境判断 ==================== -->
    <springProfile name="!prod">
        <property name="LOG_FORMAT" value="CONSOLE"/>
    </springProfile>
    <springProfile name="prod">
        <property name="LOG_FORMAT" value="JSON"/>
    </springProfile>

    <!-- ==================== 控制台输出（开发环境） ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %cyan([%X{traceId:-NOTRACE}]) %green([%X{spanId:-}]) %magenta([%X{mode:-}]) %yellow([%X{chatId:-}]) --- [%15.15t] %-40.40logger{39} : %msg%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== JSON 输出（生产环境，ELK 采集） ==================== -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!--
                JSON 格式日志字段说明：
                  timestamp   - 日志时间
                  level       - 日志级别
                  traceId     - 全链路追踪 ID
                  chatId      - 会话 ID
                  mode        - 模式：FunctionCalling / Graph
                  thread      - 线程名
                  logger      - 类名
                  message     - 日志内容
                  exception   - 异常堆栈（如有）
            -->
            <pattern>
                {"timestamp":"%d{yyyy-MM-dd HH:mm:ss.SSS}","level":"%level","traceId":"%X{traceId:-NOTRACE}","spanId":"%X{spanId:-}","chatId":"%X{chatId:-}","mode":"%X{mode:-}","thread":"%thread","logger":"%logger{36}","message":"%msg"}%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 文件输出（可选，按需启用） ==================== -->
    <!--
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>{"timestamp":"%d{ISO8601}","level":"%level","traceId":"%X{traceId:-NOTRACE}","chatId":"%X{chatId:-}","mode":"%X{mode:-}","thread":"%thread","logger":"%logger{36}","message":"%msg"}%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    -->

    <!-- ==================== 全局日志级别 ==================== -->
    <root level="INFO">
        <appender-ref ref="${LOG_FORMAT}"/>
        <!-- <appender-ref ref="FILE"/> -->
    </root>

    <!-- 项目包日志级别 -->
    <logger name="com.drafire" level="INFO"/>

    <!-- 第三方库日志级别 -->
    <logger name="com.alibaba.cloud.ai.dashscope" level="WARN"/>
    <logger name="org.springframework.web.client" level="WARN"/>
    <logger name="org.springframework.ai" level="WARN"/>
    <logger name="io.netty" level="WARN"/>

</configuration>